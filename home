<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Site Title</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    /* ─── Variables ─────────────────────────────────────────── */
    :root {
      --bg:          #f5f2ec;
      --sidebar-bg:  #1a1a18;
      --text:        #1a1a18;
      --text-muted:  #7a7972;
      --accent:      #c8a96e;
      --card-bg:     #ffffff;
      --border:      #e2ddd5;

      --sidebar-w:   30%;
      --content-w:   70%;
      --gap:         2rem;
      --card-radius: 6px;
    }

    /* ─── Reset ─────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }

    /* ─── Layout ─────────────────────────────────────────────── */
    html, body {
      height: 100%;
      overflow: hidden;
      background: var(--bg);
      font-family: 'DM Sans', sans-serif;
      color: var(--text);
    }

    .layout {
      display: flex;
      height: 100vh;
    }

    /* ─── Sidebar ────────────────────────────────────────────── */
    .sidebar {
      width: var(--sidebar-w);
      height: 100vh;
      position: fixed;
      top: 0;
      left: 0;
      background: var(--sidebar-bg);
      display: flex;
      flex-direction: column;
      padding: 3rem 2.5rem;
      color: #f5f2ec;
    }

    .sidebar-brand {
      margin-bottom: 3rem;
    }

    .sidebar-brand h1 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.6rem;
      font-weight: 400;
      letter-spacing: -0.01em;
      line-height: 1.2;
      color: #f5f2ec;
    }

    .sidebar-brand p {
      margin-top: 0.5rem;
      font-size: 0.78rem;
      font-weight: 300;
      color: var(--accent);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .sidebar-divider {
      width: 32px;
      height: 1px;
      background: var(--accent);
      margin-bottom: 2.5rem;
      opacity: 0.6;
    }

    nav ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    nav ul li a {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.6rem 0.75rem;
      border-radius: 4px;
      font-size: 0.9rem;
      font-weight: 400;
      color: #c8c5bc;
      transition: background 0.15s, color 0.15s;
    }

    nav ul li a:hover,
    nav ul li a.active {
      background: rgba(200, 169, 110, 0.1);
      color: var(--accent);
    }

    nav ul li a .nav-icon {
      width: 16px;
      height: 16px;
      opacity: 0.6;
      flex-shrink: 0;
    }

    nav ul li a.active .nav-icon { opacity: 1; }

    .sidebar-footer {
      margin-top: auto;
      font-size: 0.72rem;
      color: #4a4a45;
      line-height: 1.6;
    }

    /* ─── Main content ───────────────────────────────────────── */
    .main {
      margin-left: var(--sidebar-w);
      width: var(--content-w);
      height: 100vh;
      overflow-y: scroll;
      background: var(--bg);
    }

    .main-inner {
      padding: 3rem 3rem 5rem;
    }

    /* ─── Page header ────────────────────────────────────────── */
    .page-header {
      margin-bottom: 2.5rem;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 1rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--border);
    }

    .page-header h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 2rem;
      font-weight: 400;
      letter-spacing: -0.02em;
    }

    .page-header p {
      font-size: 0.85rem;
      color: var(--text-muted);
      font-weight: 300;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.55rem 1.2rem;
      background: var(--text);
      color: var(--bg);
      border: none;
      border-radius: var(--card-radius);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.82rem;
      font-weight: 500;
      cursor: pointer;
      letter-spacing: 0.02em;
      transition: opacity 0.15s;
      white-space: nowrap;
    }

    .btn:hover { opacity: 0.75; }

    .btn-ghost {
      background: transparent;
      color: var(--text);
      border: 1px solid var(--border);
    }

    .btn-ghost:hover { background: var(--border); opacity: 1; }

    /* ─── Card grid ──────────────────────────────────────────── */
    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: var(--gap);
    }

    .card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: var(--card-radius);
      overflow: hidden;
      transition: box-shadow 0.2s, transform 0.2s;
    }

    .card:hover {
      box-shadow: 0 8px 32px rgba(0,0,0,0.08);
      transform: translateY(-2px);
    }

    .card-thumb {
      width: 100%;
      aspect-ratio: 16/10;
      background: var(--bg);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      border-bottom: 1px solid var(--border);
    }

    .card-body {
      padding: 1.25rem;
    }

    .card-tag {
      display: inline-block;
      font-size: 0.68rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.5rem;
    }

    .card-title {
      font-family: 'DM Serif Display', serif;
      font-size: 1.05rem;
      font-weight: 400;
      line-height: 1.3;
      margin-bottom: 0.5rem;
    }

    .card-desc {
      font-size: 0.82rem;
      color: var(--text-muted);
      line-height: 1.6;
      font-weight: 300;
    }

    .card-footer {
      padding: 0.9rem 1.25rem;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .card-footer a {
      font-weight: 500;
      color: var(--text);
      font-size: 0.78rem;
      transition: color 0.15s;
    }

    .card-footer a:hover { color: var(--accent); }
  </style>
</head>
